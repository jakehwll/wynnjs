{
  "name": "@wynnjs/api",
  "version": "3.0.0",
  "description": "TypeScript client for the Wynncraft API v3",
  "keywords": [
    "api",
    "client",
    "sdk",
    "typescript",
    "wynn",
    "wynncraft"
  ],
  "homepage": "https://github.com/jakehwll/wynnjs#readme",
  "bugs": {
    "url": "https://github.com/jakehwll/wynnjs/issues"
  },
  "license": "MIT",
  "author": "Jake Howell (https://github.com/jakehwll)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jakehwll/wynnjs.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc --noEmit -p tsconfig.examples.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fixtures": "bun run scripts/sync-fixtures.ts",
    "ci": "bun run lint && bun run format:check && bun run typecheck && bun run test && bun run build && bun run typecheck:examples && npm pack --dry-run"
  },
  "dependencies": {
    "axios": "^1.18.1"
  },
  "devDependencies": {
    "@types/axios-mock-adapter": "^1.10.4",
    "@types/bun": "latest",
    "@types/node": "^26.1.1",
    "axios-mock-adapter": "^2.1.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "zod": "^4.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
