{
  "name": "wynnjs",
  "private": true,
  "homepage": "https://jakehwll.github.io/wynnjs/",
  "bugs": {
    "url": "https://github.com/jakehwll/wynnjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jakehwll/wynnjs.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter '@wynnjs/*' --if-present build",
    "typecheck": "bun run --filter '@wynnjs/*' --if-present typecheck",
    "typecheck:examples": "bun run --filter '@wynnjs/api' --if-present typecheck:examples",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "bun run --filter '@wynnjs/*' --if-present test",
    "test:watch": "bun run --filter '@wynnjs/*' --if-present test:watch",
    "test:fixtures": "bun run --filter '@wynnjs/*' --if-present test:fixtures",
    "docs": "bun run --filter @wynnjs/docs dev",
    "docs:build": "bun run --filter @wynnjs/docs build",
    "docs:preview": "bun run --filter @wynnjs/docs preview",
    "ci": "bun run lint && bun run format:check && bun run typecheck && bun run test && bun run build && bun run typecheck:examples && npm pack --dry-run -w @wynnjs/api"
  },
  "devDependencies": {
    "@types/axios-mock-adapter": "^1.10.4",
    "@types/bun": "latest",
    "@types/node": "^26.1.1",
    "axios-mock-adapter": "^2.1.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18"
  }
}
