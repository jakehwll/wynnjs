{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {},
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "bun.lock",
    "*.tgz",
    "apps/docs/.vitepress/cache/**",
    "apps/docs/.vitepress/dist/**"
